# Datenbank (Supabase PostgreSQL)
# App-URL (Transaction Pooler, Port 6543) mit PgBouncer-Kompatibilität für Prisma
DATABASE_URL="postgresql://postgres:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Optional für Prisma-Migrationen (Session Mode, Port 5432)
DIRECT_URL="postgresql://postgres:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="ein-sicherer-zufaelliger-string-hier-eingeben"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI API
OPENAI_API_KEY="sk-..."
OPENAI_MODEL_MEALPLAN_STRUCTURE="gpt-4o-mini"
OPENAI_MODEL_MEALPLAN_RECIPES="gpt-4o-mini"
OPENAI_MODEL_MEALPLAN_VALIDATION="gpt-4o-mini"
OPENAI_MODEL_MEALPLAN_SCORING="gpt-4o-mini"

# Resend (Transaktionale E-Mails)
RESEND_API_KEY="re_..."
# WICHTIG: In Produktion eine verifizierte Domain-Adresse nutzen (kein resend.dev)
EMAIL_FROM="mein-nutrikompass.de <noreply@mein-nutrikompass.de>"
EMAIL_REPLY_TO="support@mein-nutrikompass.de"

# Stripe (Billing)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_BASIC="price_..."
STRIPE_PRICE_ID_PROFESSIONAL="price_..."

# Sentry (Error-Tracking) – https://sentry.io
# DSN aus Sentry-Dashboard: Settings → Projects → [Projekt] → Client Keys
NEXT_PUBLIC_SENTRY_DSN=""
# Für CI/Build Sourcemap-Upload (optional):
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# FHIR Export (MVP)
FHIR_EXPORT_ADMIN_ONLY="true"
FHIR_EXPORT_RATE_LIMIT_MAX="10"
FHIR_EXPORT_RATE_LIMIT_WINDOW_MS="3600000"
FHIR_EXPORT_MAX_PAYLOAD_BYTES="5242880"
AGENT_COMMIT_ADMIN_ONLY="true"
AGENT_COMMIT_TX_TIMEOUT_MS="20000"
AGENT_COMMIT_TX_MAX_WAIT_MS="5000"
