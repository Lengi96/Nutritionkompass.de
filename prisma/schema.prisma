generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum UserDefaultLandingPage {
  DASHBOARD
  PATIENTS
  MEAL_PLANS
  SHOPPING_LISTS
}

enum UiDensity {
  COMFORTABLE
  COMPACT
}

enum SubscriptionPlan {
  TRIAL
  BASIC
  PROFESSIONAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  contactEmail String?
  contactPhone String?
  websiteUrl   String?
  addressLine  String?
  postalCode   String?
  city         String?
  country      String?
  profileNotes String?   @db.Text
  createdAt DateTime  @default(now())

  // Stripe & Subscription
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?
  subscriptionPlan     SubscriptionPlan   @default(TRIAL)
  subscriptionStatus   SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?

  users                User[]
  patients             Patient[]
  invitations          StaffInvitation[]
  autonomyAgreements   AutonomyAgreement[]
  fhirExportAuditLogs  FhirExportAuditLog[]
  agentAuditLogs       AgentAuditLog[]
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String       @unique
  passwordHash   String
  name           String
  jobTitle       String?
  phone          String?
  profileNotes   String?      @db.Text
  role           Role         @default(STAFF)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  settings       UserSettings?
  mealPlans      MealPlan[]

  // E-Mail-Verifizierung
  emailVerified                Boolean   @default(false)
  emailVerificationToken       String?   @unique
  emailVerificationTokenExpiresAt DateTime?

  // Passwort-Reset
  resetToken             String?   @unique
  resetTokenExpiresAt    DateTime?

  // Autonomie-Relationen
  createdAgreements      AutonomyAgreement[]  @relation("AgreementCreatedBy")
  auditLogEntries        AutonomyAuditLog[]   @relation("AuditChangedBy")
  fhirExportAuditLogs    FhirExportAuditLog[]
  agentAuditLogs         AgentAuditLog[]

  @@index([organizationId])
  @@index([email])
}

model UserSettings {
  id                 String                 @id @default(cuid())
  userId             String                 @unique
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultLandingPage UserDefaultLandingPage @default(DASHBOARD)
  uiDensity          UiDensity              @default(COMFORTABLE)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

model Patient {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  pseudonym      String
  birthYear      Int
  currentWeight  Decimal       @db.Decimal(5, 2)
  targetWeight   Decimal       @db.Decimal(5, 2)
  targetDate     DateTime?     // Optionales Zieldatum fÃ¼r Gewichtsziel
  allergies      String[]
  fearFoods      String[]      // Angst-/Triggerlebensmittel (EssstÃ¶rungstherapie)
  notes          String?
  autonomyNotes  String?       // Legacy â€“ wird durch AutonomyAgreement ersetzt
  isActive       Boolean       @default(true)
  weightHistory  WeightEntry[]
  mealPlans      MealPlan[]
  createdAt      DateTime      @default(now())
  createdBy      String

  // Autonomie-System
  autonomyAgreement  AutonomyAgreement?
  autonomyAuditLogs  AutonomyAuditLog[]

  @@index([organizationId])
}

model WeightEntry {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  weightKg   Decimal  @db.Decimal(5, 2)
  recordedAt DateTime @default(now())
  recordedBy String

  @@index([patientId])
}

model MealPlan {
  id            String        @id @default(cuid())
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  weekStart     DateTime
  planJson      Json
  totalKcal     Int
  promptUsed    String        @db.Text
  createdBy     String
  createdByUser User          @relation(fields: [createdBy], references: [id])
  shoppingList  ShoppingList?
  createdAt     DateTime      @default(now())

  @@index([patientId])
  @@index([createdBy])
}

model ShoppingList {
  id         String   @id @default(cuid())
  mealPlanId String   @unique
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  itemsJson  Json
  createdAt  DateTime @default(now())
}

model StaffInvitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String
  name           String
  role           Role         @default(STAFF)
  token          String       @unique
  expiresAt      DateTime
  invitedBy      String
  createdAt      DateTime     @default(now())

  @@unique([organizationId, email])
  @@index([token])
}

// Autonomie-Absprachen â€“ Strukturierte SelbststÃ¤ndigkeitsvereinbarungen
model AutonomyAgreement {
  id                     String       @id @default(cuid())
  patientId              String       @unique
  patient                Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id])

  // Portionier-Absprachen
  canPortionSupervised   Boolean      @default(false) // Darf unter Aufsicht portionieren
  canPortionIndependent  Boolean      @default(false) // Darf vollstÃ¤ndig eigenstÃ¤ndig portionieren

  notes                  String?      // Freitext: z.B. "Gilt nur beim Abendessen"
  validFrom              DateTime
  validUntil             DateTime?    // null = unbefristet

  createdBy              String
  createdByUser          User         @relation("AgreementCreatedBy", fields: [createdBy], references: [id])
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  auditLogs              AutonomyAuditLog[]

  @@index([patientId])
  @@index([organizationId])
}

// UnverÃ¤nderliches Audit-Log â€“ Dokumentiert jede Ã„nderung an Absprachen
model AutonomyAuditLog {
  id            String            @id @default(cuid())
  patientId     String
  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  agreementId   String
  agreement     AutonomyAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  changedBy     String
  changedByUser User              @relation("AuditChangedBy", fields: [changedBy], references: [id])
  changedAt     DateTime          @default(now())

  fieldChanged  String            // z.B. "canPortionSupervised" oder "CREATED"
  oldValue      String            // Vorheriger Wert als String
  newValue      String            // Neuer Wert als String
  reason        String            // BegrÃ¼ndung (Pflichtfeld, min. 10 Zeichen)

  @@index([patientId])
  @@index([agreementId])
}

model FhirExportAuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  patientIds     String[]
  resourceTypes  String[]
  dateFrom       DateTime?
  dateTo         DateTime?
  payloadBytes   Int
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
}

model AgentAuditLog {
  id                  String       @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  userId              String
  user                User         @relation(fields: [userId], references: [id])
  createdAt           DateTime     @default(now())
  intentSummary       String
  proposedActionsJson Json
  committed           Boolean      @default(false)
  commitResultJson    Json?

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

